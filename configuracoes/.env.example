# AnalysisSupreme - Configurações de Ambiente
# Copie este arquivo para .env e configure suas chaves

# Modo de operação (paper/live)
PAPER_MODE=true

# Configurações de Exchange - Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_secret_here
BINANCE_SANDBOX=true

# Configurações de Exchange - Bybit
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_secret_here
BYBIT_SANDBOX=true

# Configurações de Exchange - OKX
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_SANDBOX=true

# Configurações de IA
OPENAI_API_KEY=your_openai_key_here
HUGGINGFACE_API_KEY=your_hf_key_here

# Configurações de Observabilidade
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOG_LEVEL=INFO

# Configurações de Risco
MAX_RISK_PERCENT=2.0
MAX_POSITION_SIZE=1000
STOP_LOSS_PERCENT=2.0

# Configurações de Performance
TARGET_LATENCY_MS=120
ARBITRAGE_TARGET_LATENCY_MS=50
SCALPING_TARGET_LATENCY_MS=30

# Configurações de KPIs
ARBITRAGE_MIN_SPREAD=0.3
GRID_MIN_EFFICIENCY=70.0
MOMENTUM_MIN_PRECISION=65.0
SCALPING_MIN_THROUGHPUT=100.0
MEAN_REVERSION_MIN_DETECTION=70.0
SWING_MIN_CAPTURE=60.0

# Configurações de Banco de Dados
DATABASE_URL=sqlite:///analysissupreme.db
REDIS_URL=redis://localhost:6379

# Configurações de Notificações
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Configurações de Desenvolvimento
DEBUG=false
TEST_MODE=false
COVERAGE_THRESHOLD=80
