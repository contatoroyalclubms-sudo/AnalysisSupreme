# === MODO DE OPERAÇÃO ===
MODO=paper  # paper, backtest, live
DEBUG=true

# === EXCHANGES ===
EXCHANGES=binance,bybit,okx
TIMEOUT_API_SEGUNDOS=10
RETRY_MAX_TENTATIVAS=3

# === CHAVES API (SECRETS DO GITHUB!) ===
API_KEY_BINANCE=__GITHUB_SECRET__
API_SECRET_BINANCE=__GITHUB_SECRET__
API_KEY_BYBIT=__GITHUB_SECRET__
API_SECRET_BYBIT=__GITHUB_SECRET__
API_KEY_OKX=__GITHUB_SECRET__
API_SECRET_OKX=__GITHUB_SECRET__

# === GESTÃO DE RISCO ===
CAPITAL_TOTAL_USD=10000
RISCO_MAX_PCT_POR_TRADE=1.0
RISCO_MAX_PCT_DIARIO=5.0
STOP_LOSS_GLOBAL_PCT=10.0

# === PERFORMANCE ===
LATENCIA_ALVO_MS=120
SLIPPAGE_MAX_BPS=15
VOLUME_MIN_USD=100

# === IA & OTIMIZAÇÃO ===
IA_HABILITADA=true
AUTO_TUNING_HABILITADO=true
SENTIMENT_ANALYSIS_HABILITADO=true
APRENDIZADO_CONTINUO_HABILITADO=true

# === OBSERVABILIDADE ===
LOG_LEVEL=INFO
PROMETHEUS_HABILITADO=true
GRAFANA_HABILITADO=true
RELATORIO_AUTO_GERADO=true

# === PERFORMANCE SETTINGS ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
WEBSOCKET_MAX_CONNECTIONS=5
CACHE_TTL_TICKER_MS=100
CACHE_TTL_ORDERBOOK_MS=50
CACHE_TTL_OHLCV_MS=1000
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
PARALLEL_BOT_EXECUTION=true
PERFORMANCE_MONITORING=true
