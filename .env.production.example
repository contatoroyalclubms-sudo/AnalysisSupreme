# Production Environment Variables Template
# Copy this file to .env.production and configure your values

ENVIRONMENT=production
DEBUG=False

# Database Configuration
DATABASE_URL=postgresql://cryptobot:CHANGE_ME_STRONG_PASSWORD@localhost:5432/cryptobot_prod
POSTGRES_DB=cryptobot_prod
POSTGRES_USER=cryptobot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=CHANGE_ME_VERY_STRONG_SECRET_KEY_32_CHARS_MIN

# Exchange API Keys (CONFIGURE THESE!)
API_KEY_BINANCE=your_binance_api_key_here
API_SECRET_BINANCE=your_binance_secret_here
API_KEY_COINBASE=your_coinbase_api_key_here
API_SECRET_COINBASE=your_coinbase_secret_here

# Security
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
LOG_LEVEL=INFO

# Performance
WORKERS=4
MAX_CONNECTIONS=100
CACHE_TTL_DEFAULT=300
CACHE_TTL_MARKET_DATA=60
CACHE_TTL_SIGNALS=30
CACHE_TTL_ML_PREDICTIONS=300

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# SSL/TLS
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Alerts
ALERT_EMAIL=admin@yourdomain.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
